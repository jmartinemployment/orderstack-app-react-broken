# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Pooler URL — used for all runtime queries (Supabase Supavisor in transaction
# mode is the equivalent of PgBouncer; required for schema-per-tenant isolation)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Direct URL — used only for Drizzle migrations (bypasses the pooler)
# Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=

# ─── Redis (Render Redis or Upstash) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-32-char-minimum-secret

# ─── Device Certificates (RS256 asymmetric key pair) ─────────────────────────
# Generate with: openssl genrsa -out device_private.pem 2048
#                openssl rsa -in device_private.pem -pubout -out device_public.pem
# Store the full PEM content as a single-line string with \n for newlines
DEVICE_CERT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
DEVICE_CERT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
DEVICE_CERT_TTL=31536000

# ─── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@orderstack.io
RESEND_FROM_NAME=OrderStack

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=orderstack-assets
CLOUDFLARE_R2_PUBLIC_URL=https://assets.orderstack.io

# ─── Search (Meilisearch) ─────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=

# ─── Accounting Integrations ──────────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://api.orderstack.io/v1/accounting/connect/quickbooks/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://api.orderstack.io/v1/accounting/connect/xero/callback

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_BACKOFFICE=

# ─── Analytics ────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=info
